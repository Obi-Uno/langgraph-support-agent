# Choose your LLM backend: "gemini" or "groq" (both free-tier, good for local
# testing) or "anthropic" (paid, what you'd likely run in production once you
# have credits)
LLM_PROVIDER=groq

# Only fill in the key for whichever provider you selected above
GOOGLE_API_KEY=your_google_ai_studio_key_here
GROQ_API_KEY=your_groq_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the default model for your chosen provider
AGENT_MODEL=

# Optional: override the small model used by the relevance guardrail
GUARD_MODEL=

DATABASE_URL=sqlite:///./support_agent.db
N8N_WEBHOOK_SECRET=change_me_shared_secret
ESCALATION_REFUND_THRESHOLD=500
